LIVEKIT_URL=
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=

# Moss — semantic search / memory (https://docs.moss.dev/docs)
# MOSS_PROJECT_ID / MOSS_PROJECT_KEY are filled in at index/run time (Task 9).
MOSS_PROJECT_ID=
MOSS_PROJECT_KEY=
MOSS_INDEX_NAME=knowledge
MOSS_MEMORY_INDEX_NAME=memory
MOSS_MODEL_ID=moss-minilm

# TrueFoundry AI Gateway (optional — routes to MiniMax)
TRUEFOUNDRY_API_KEY=
TRUEFOUNDRY_ENDPOINT=https://llm-gateway.truefoundry.com/api/inference/openai

# Optional for hosted hackathon demos: allow /api/token without full auth.
ALLOW_PUBLIC_DEMO=false
